{
  "name": "@notfounnd/marc-server",
  "version": "0.2.0",
  "description": "mARC is a local coordination layer for coding agents. It gives humans and agents a shared Markdown workspace where tasks become threads, long context becomes artifacts, project guidance stays close to the code, and every participant can catch up without scraping an entire chat history.",
  "author": "Júnior Sbrissa",
  "license": "MIT",
  "homepage": "https://github.com/notfounnd/marc-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notfounnd/marc-server.git"
  },
  "bugs": {
    "url": "https://github.com/notfounnd/marc-server/issues"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.10.0",
  "bin": {
    "marc": "./dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && vite build",
    "dev:daemon": "tsx src/cli.ts daemon",
    "dev:mcp": "tsx src/cli.ts mcp",
    "dev:ui": "vite --host 127.0.0.1",
    "lint:check": "eslint src/**/*.{ts,tsx} test/**/*.ts eslint.config.js",
    "lint:fix": "eslint src/**/*.{ts,tsx} test/**/*.ts eslint.config.js --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "code:check": "pnpm run lint:check && pnpm run format:check",
    "code:fix": "pnpm run lint:fix && pnpm run format:fix",
    "validate": "pnpm run code:fix && pnpm run code:check && pnpm run typecheck",
    "test": "node --test --import tsx test/**/*.test.ts",
    "test:benchmark": "pnpm dlx tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.1.0",
    "i18next-http-backend": "^4.0.0",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^7.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
